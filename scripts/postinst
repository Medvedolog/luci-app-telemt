#!/bin/sh
[ "${IPKG_NO_SCRIPT}" = "1" ] && exit 0
echo "========================================================"
echo " Configuring telemt core v3.2.2-1 "
echo "========================================================"

# 1. Мягко убиваем любые запущенные "левые" процессы telemt (Защита от совпадений имени с ботом)
echo "[*] Checking for running standalone telemt processes..."
t_pid=$(pidof telemt | awk '{print $1}')
if [ -n "$t_pid" ]; then
    /etc/init.d/telemt stop 2>/dev/null || true
    kill -9 "$t_pid" 2>/dev/null || true
fi

# 2. Изолируем старые ручные конфиги, чтобы юзер их не потерял, но они не мешали UCI
echo "[*] Checking for standalone configuration folders..."
if [ -d "/etc/telemt" ]; then
    mv /etc/telemt /etc/telemt.disabled_by_luci 2>/dev/null || true
    echo "    -> Moved /etc/telemt to /etc/telemt.disabled_by_luci"
fi

# 3. Включаем службу
echo "[*] Enabling telemt service..."
/etc/init.d/telemt enable 2>/dev/null || true
exit 0
